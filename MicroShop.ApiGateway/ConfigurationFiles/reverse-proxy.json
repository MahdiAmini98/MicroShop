{
  "ReverseProxy": {
    "Routes": {
      "product-swagger-route": {
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/swagger-json/product/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/swagger-json/product" } ]
      },
      "basket-swagger-route": {
        "ClusterId": "basket-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/swagger-json/basket/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/swagger-json/basket" } ]
      },
      "order-swagger-route": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/swagger-json/order/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/swagger-json/order" } ]
      },
      "payment-swagger-route": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/swagger-json/payment/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/swagger-json/payment" } ]
      },
      "discount-grpc-route": {
        "ClusterId": "discount-grpc-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": {
          "Path": "/DiscountServiceProto/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/DiscountServiceProto" }
        ]
      }
    },
    "Clusters": {
      "product-cluster": {
        "Destinations": {
          "product-destination": {
            "Address": "https://localhost:7182/"
          }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "basket-destination": {
            "Address": "https://localhost:7247/"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-destination": {
            "Address": "https://localhost:7092/"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-destination": {
            "Address": "https://localhost:7122/"
          }
        }
      },
      "discount-grpc-cluster": {
        "HttpRequest": {
          "Version": "2",
          "VersionPolicy": "RequestVersionExact"
        },
        "Destinations": {
          "discount-destination": {
            "Address": "http://localhost:7134/"
          }
        }
      }
    }
  }
}