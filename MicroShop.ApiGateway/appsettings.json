{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Key": "microshop-super-secret-key-minimum-32-characters-long-here",
    "Issuer": "MicroShopGateway",
    "Audience": "MicroShopServices",
    "ExpiresInMinutes": 60,
    "RequireHttpsMetadata": false
  },

  "Gateway": {
    "Name": "MicroShop API Gateway",
    "BaseUrl": "https://localhost:5000",
    "EnableSwagger": true,
    "EnableDetailedErrors": true
  },

  "Cors": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": [
      "https://localhost:7000",
      "https://localhost:8000"
    ],

    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "PATCH",
      "OPTIONS"
    ],

    "AllowedHeaders": [
      "Content-Type",
      "Authorization",
      "X-Correlation-ID"
    ],

    "AllowCredentials": true,

    "PreflightMaxAgeSeconds": 3600
  },

  "SecurityHeaders": {
    "Enabled": true,
    "ContentTypeOptionsNoSniff": true,
    "XFrameOptions": "DENY",
    "ReferrerPolicy": "strict-origin-when-cross-origin",
    "PermissionsPolicy": "camera=(), microphone=(), geolocation=(), payment=()",
    "ContentSecurityPolicy": null, //"default-src 'none'; frame-ancestors 'none'",
    "EnableHsts": false,
    "HstsMaxAgeSeconds": 31536000,
    "HstsIncludeSubDomains": true,
    "HstsPreload": false,
    "AddRequestId": true,
    "RemoveServerHeader": true
  },

  "AuthForwarding": {
    "Enabled": true,
    "ForwardBearerToken": true,
    "UseCustomHeader": false,
    "CustomHeaderName": "X-Internal-Token",
    "GatewayHeader": "X-Gateway-Name",
    "GatewayHeaderValue": "MicroShop-Gateway",
    "IsAuthenticatedHeader": "X-Is-Authenticated"
  },

  "ClaimsMapping": {
    "Enabled": true,
    "Mappings": {
      "sub": "X-User-Id",
      "name": "X-User-Name",
      "email": "X-User-Email",
      "preferred_username": "X-User-Username",

      "nameidentifier": "X-User-Id",
      "fullname": "X-User-Name",
      "emailaddress": "X-User-Email"
    },
    "RoleClaimTypes": [
      "role",
      "roles",
      "http://schemas.microsoft.com/ws/2008/06/identity/claims/role"
    ],
    "RolesHeaderName": "X-User-Roles",
    "ExcludedClaims": [
      "iat",
      "exp",
      "nbf",
      "aud",
      "iss",
      "nonce",
      "at_hash",
      "c_hash",
      "password",
      "refresh_token"
    ]
  },

  "Redis": {
    "IsEnabled": true,
    "ConnectionString": "localhost:6379",
    "DefaultTtlSeconds": 300,
    "InstanceName": "MicroShopGateway:"
  },

  "RateLimit": {
    "PermitLimit": 100, //حداکثر ظرفیت bucket
    "TokensPerPeriod": 10, //هر بار refill:"چند" "token", "اضافه" "شود.",
    "ReplenishmentPeriodSeconds": 10 //هر "چند" ثانیه یکبار bucket "refill" شود.
  },

  "SwaggerAggregation": {
    "Enabled": true,
    "RoutePrefix": "swagger",
    "Title": "MicroShop API Gateway",
    "Version": "v1",
    "Description": "Unified API Documentation for All Microservices",
    "RequireAuthentication": false,
    "SwaggerJsonPrefix": "/swagger-json"
  }

}