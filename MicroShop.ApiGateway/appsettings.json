{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Key": "microshop-super-secret-key-minimum-32-characters-long-here",
    "Issuer": "MicroShopGateway",
    "Audience": "MicroShopServices",
    "ExpiresInMinutes": 60,
    "RequireHttpsMetadata": false
  },

  "Gateway": {
    "Name": "MicroShop API Gateway",
    "BaseUrl": "https://localhost:5000",
    "EnableSwagger": true,
    "EnableDetailedErrors": true
  },

  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7000",
      "https://localhost:8000"
    ],

    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "PATCH",
      "OPTIONS"
    ],

    "AllowedHeaders": [
      "Content-Type",
      "Authorization",
      "X-Correlation-ID"
    ],

    "AllowCredentials": true,

    "PreflightMaxAgeSeconds": 3600
  },

  "RateLimit": {
    "PermitLimit": 20,
    "WindowSeconds": 10,
    "QueueLimit": 0,
    "Algorithm": "FixedWindow",
    "Enabled": true
  },

  "Redis": {
    "ConnectionString": "localhost:6379",
    "DefaultTtlSeconds": 300,
    "IsEnabled": true
  },

  "SecurityHeaders": {
    "Enabled": true,
    "ContentTypeOptionsNoSniff": true,
    "XFrameOptions": "DENY",
    "ReferrerPolicy": "strict-origin-when-cross-origin",
    "PermissionsPolicy": "camera=(), microphone=(), geolocation=(), payment=()",
    "ContentSecurityPolicy": null, //"default-src 'none'; frame-ancestors 'none'",
    "EnableHsts": false,
    "HstsMaxAgeSeconds": 31536000,
    "HstsIncludeSubDomains": true,
    "HstsPreload": false,
    "AddRequestId": true,
    "RemoveServerHeader": true
  }

}