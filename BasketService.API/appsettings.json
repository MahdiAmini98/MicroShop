{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "BasketConnection": "Data Source=.;Initial Catalog=MicroShop_BasketService_DB;Integrated Security=true;MultipleActiveResultSets=true;TrustServerCertificate=true;"
  },

  "MicroservicAddress": {
    "Discount": {
      "Uri": "https://localhost:7134/"
    }
  },

